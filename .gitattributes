# Normalize line endings
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Config
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Docs
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.docx binary
